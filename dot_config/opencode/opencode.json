{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "CONTRIBUTING.md",
    "AGENTS.md",
    ".cursor/rules/*.md",
    "CLAUDE.md",
    "README.md"
  ],
  "mcp": {
    "linear": {
      "type": "local",
      "command": ["bun", "x", "mcp-remote", "https://mcp.linear.app/mcp"],
      "enabled": true
    }
  },
  "permission": {
    "edit": "allow",
    "bash": {
      "grep": "allow",
      "cd": "allow",
      "ls": "allow",
      "cat": "allow",
      "pwd": "allow",
      "mkdir": "allow",
      "bun": "allow",
      "npm": "deny",
      "*": "allow"
    },
    "webfetch": "allow"
  }
}
